{
  "name": "agent-glance",
  "version": "0.0.4",
  "description": "MCP server providing a shared HUD ('glance') for AI agents — singleton daemon, stdio adapter, multi-client.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-glance": "dist/index.js"
  },
  "files": [
    "dist",
    "media",
    "scripts"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "postinstall": "node scripts/apply-glimpseui-patch.mjs",
    "prepublishOnly": "npm run build && npm test",
    "daemon": "npm run build && AGENT_GLANCE_ROLE=daemon AGENT_GLANCE_IDLE_MS=0 node ./dist/index.js",
    "smoke": "npm run build && node ./examples/mcp-smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "agent",
    "hud",
    "glance",
    "glimpseui"
  ],
  "author": "Dying",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyingg/agent-glance.git"
  },
  "homepage": "https://github.com/dyingg/agent-glance#readme",
  "bugs": {
    "url": "https://github.com/dyingg/agent-glance/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glimpseui": "0.8.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
