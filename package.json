{
  "name": "clawd-docklet",
  "version": "0.0.1",
  "description": "MCP server shell with singleton daemon architecture for shared glimpseui UI across multiple agent sessions.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "clawd-docklet": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "postinstall": "patch-package",
    "prepublishOnly": "npm run build && npm test",
    "daemon": "npm run build && CLAWD_DOCKLET_ROLE=daemon CLAWD_DOCKLET_IDLE_MS=0 node ./dist/index.js",
    "smoke": "npm run build && node ./examples/mcp-smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glimpseui": "^0.8.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
